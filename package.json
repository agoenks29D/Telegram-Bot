{
  "name": "telegram-bot",
  "version": "1.1.0",
  "description": "Telegram Bot Starter Kit",
  "keywords": [
    "bot",
    "telegram",
    "telegram-bot",
    "starter-kit"
  ],
  "author": "Agung Dirgantara <agungmasda29@gmail.com>",
  "license": "MIT",
  "main": "dist/main.js",
  "scripts": {
    "build": "swc -s --strip-leading-paths -d dist src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "node dist/main.js",
    "start:dev": "concurrently \"npm run build -- --watch\" \"nodemon dist/main.js --delay 1\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write --ignore-unknown",
      "eslint --fix"
    ],
    "*.{json,yaml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "@faker-js/faker": "^9.8.0",
    "@telegraf/session": "^2.0.0-beta.7",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "html-entities": "^2.6.0",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.48",
    "redis": "^4.7.1",
    "telegraf": "^4.16.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.11.24",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.3",
    "chokidar": "^5.0.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.26.0",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.14",
    "prettier": "3.5.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.spec.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": {
            "paths": {
              "@/*": [
                "./src/*"
              ]
            }
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/__tests__/**",
      "!src/**/*.d.ts",
      "!src/main.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "clearMocks": true,
    "restoreMocks": true
  }
}
